# ─────────────────────────────────────────────────────────────────────────────
# QDRN Radar — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---------------------------------------------------------------------
# Public base path the app is served under (matches radar.qdrn.io/md)
BASE_PATH=/md
# Port the qdrn-radar app listens on inside the Pi / container
PORT=8080
NODE_ENV=production

# --- Receiver / map ----------------------------------------------------------
# City-level only (NOT the exact home address). Used to center the map.
RECEIVER_LAT=39.0458
RECEIVER_LON=-76.6413
RECEIVER_CITY=Maryland
# Default range ring radii in nautical miles (comma separated)
RANGE_RINGS_NM=50,100,150
# MapLibre style URL (free, no key by default — CARTO dark matter)
MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# --- Data source (ultrafeeder) -----------------------------------------------
# Where the live decoded aircraft.json is served (tar1090/readsb data dir)
AIRCRAFT_JSON_URL=http://ultrafeeder/data/aircraft.json
POLL_INTERVAL_MS=1000

# --- Setup wizard (friend-facing) --------------------------------------------
# Simple PIN the device owner types to open the easy setup wizard at /md/setup.
# Set this when you provision the Pi. Keep it short + memorable for them.
SETUP_PIN=1234

# --- Admin (you) -------------------------------------------------------------
# The admin console at /md/admin is protected by Cloudflare Access (see infra/).
# This header is injected by Cloudflare Access and verified by the app.
CF_ACCESS_TEAM_DOMAIN=qdrn.cloudflareaccess.com
CF_ACCESS_AUD=

# --- Enrichment: free sources (used by default, no signup) --------------------
ADSBDB_BASE=https://api.adsbdb.com/v0
HEXDB_BASE=https://hexdb.io/api/v1

# --- Enrichment: friend's own paid keys (added via the setup wizard) ----------
# These are normally stored in the app's config DB after onboarding, not here.
# Listed for reference / optional bootstrapping only.
FLIGHTAWARE_AEROAPI_KEY=
FLIGHTRADAR24_API_TOKEN=

# --- Feeder keys (configure fr24feed / piaware; usually set during onboarding) -
FR24_SHARING_KEY=
PIAWARE_FEEDER_ID=
