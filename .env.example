# ─────────────────────────────────────────────────────────────────────────────
# QDRN Radar — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---------------------------------------------------------------------
# Public base path the app is served under (matches radar.qdrn.io/md)
BASE_PATH=/md
# Port the qdrn-radar app listens on inside the Pi / container
PORT=8080
NODE_ENV=production

# --- Receiver / map ----------------------------------------------------------
# City-level only (NOT the exact home address). Used to center the public map.
RECEIVER_LAT=45.03
RECEIVER_LON=-93.30
RECEIVER_CITY=Minneapolis, MN
# Default range ring radii in nautical miles (comma separated)
RANGE_RINGS_NM=50,100,150

# Exact receiver location for the decoder/feeders (kept private on the Pi).
# Set these to the actual antenna location for accurate MLAT/range stats.
FEEDER_LAT=45.03
FEEDER_LON=-93.30
FEEDER_ALT=270m
TZ=America/Chicago
# MapLibre style URLs (free, no key). Light is the default theme.
MAP_STYLE_URL_LIGHT=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
MAP_STYLE_URL_DARK=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# --- Data source (ultrafeeder) -----------------------------------------------
# Where the live decoded aircraft.json is served (tar1090/readsb data dir)
AIRCRAFT_JSON_URL=http://ultrafeeder/data/aircraft.json
POLL_INTERVAL_MS=1000

# --- Setup wizard (friend-facing) --------------------------------------------
# Simple PIN the device owner types to open the easy setup wizard at /md/setup.
# Set this when you provision the Pi. Keep it short + memorable for them.
SETUP_PIN=1234

# --- Remote access / infra ---------------------------------------------------
# Cloudflare Tunnel token (token mode). See infra/cloudflared/README.md.
CF_TUNNEL_TOKEN=
# Stable feeder UUID — auto-generated by provisioning/install.sh if empty.
ULTRAFEEDER_UUID=

# --- Admin (you) -------------------------------------------------------------
# The admin console at /md/admin is protected by Cloudflare Access (see infra/).
# Comma-separated emails allowed into the admin console (matched vs CF Access).
ADMIN_EMAILS=collin@qdrn.io
CF_ACCESS_TEAM_DOMAIN=qdrn.cloudflareaccess.com
CF_ACCESS_AUD=

# --- Enrichment: free sources (used by default, no signup) --------------------
ADSBDB_BASE=https://api.adsbdb.com/v0
HEXDB_BASE=https://hexdb.io/api/v1

# --- Enrichment: friend's own paid keys (added via the setup wizard) ----------
# These are normally stored in the app's config DB after onboarding, not here.
# Listed for reference / optional bootstrapping only.
FLIGHTAWARE_AEROAPI_KEY=
FLIGHTRADAR24_API_TOKEN=

# --- Feeder keys --------------------------------------------------------------
# These are normally entered by the friend in the CaptainQ setup wizard, which
# writes them to data/feeder.env and recreates the feeder containers for you.
# You can pre-seed them here only for a manual/initial bring-up:
#   echo "FR24KEY=...\nFEEDER_ID=..." > data/feeder.env
FR24_SHARING_KEY=
PIAWARE_FEEDER_ID=
